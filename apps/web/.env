# These API keys are intentionally public. Please do not report them - thank you for your concern.
ESLINT_NO_DEV_ERRORS=true

# --- PRIMEA MODE: Disable Uniswap cloud dependencies by default ---

# Telemetry/feature flags: disable proxies unless you host equivalents
REACT_APP_AMPLITUDE_PROXY_URL=""
REACT_APP_STATSIG_PROXY_URL=""
# If you are not running Statsig, also blank the key to stop init attempts
REACT_APP_STATSIG_API_KEY=""

# Uniswap gateways: disable (prevents CORS + external dependency)
REACT_APP_UNISWAP_BASE_API_URL=""
REACT_APP_UNISWAP_GATEWAY_DNS=""
REACT_APP_TEMP_API_URL=""
REACT_APP_AWS_API_ENDPOINT=""

# Trading API (UniswapX / routing services): disable unless you host your own
REACT_APP_TRADING_API_KEY=""

# Moonpay: disable unless you intend to offer it now (it will not work cleanly without Uniswap infra)
REACT_APP_MOONPAY_API=""
REACT_APP_MOONPAY_LINK=""
REACT_APP_MOONPAY_PUBLISHABLE_KEY=""

# WalletConnect: keep your project id (but fix metadata.url separately in code/config)
REACT_APP_WALLET_CONNECT_PROJECT_ID="c6c9bacd35afa3eb9e6cccf6d8464395"

# RPC providers: keep if you still use them for mainnet/EVM chains; otherwise blank
REACT_APP_INFURA_KEY="4bf032f2d38a4ed6bb975b80d6340847"
REACT_APP_QUICKNODE_ENDPOINT_NAME="tame-frequent-fog"
REACT_APP_QUICKNODE_ENDPOINT_TOKEN="774f0081965a0e9378059e0622c2a584fb8859f2"

# Flag: You are NOT Uniswap interface
REACT_APP_IS_UNISWAP_INTERFACE=false


